{
  "name": "root",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/withstudiocms/studiocms.git"
  },
  "packageManager": "pnpm@10.17.0",
  "engines": {
    "node": ">=22.20.0"
  },
  "workspaces": [
    "packages/@studiocms/*",
    "packages/@withstudiocms/*",
    "packages/*"
  ],
  "pnpm": {
    "patchedDependencies": {
      "@changesets/assemble-release-plan": "patches/@changesets__assemble-release-plan.patch"
    }
  },
  "scripts": {
    "effect-language-service": "effect-language-service",
    "start": "node ./playground/dist/server/entry.mjs",
    "start:env": "dotenvx run -- node ./playground/dist/server/entry.mjs",

    "changeset": "changeset",
    "changeset:status": "changeset status --since=origin/main",

    "knip": "knip",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "postinstall": "ts-patch install",
    "clean:node": "node ./scripts/clean-node-modules.mjs",
    "clean:pnpm-lock": "pnpm clean:node && node ./scripts/clean-pnpm-lockfile.mjs",
    "reset:pnpm": "pnpm clean:pnpm-lock && pnpm install",

    "allure:clean": "node -e \"import('node:fs').then(({rmSync})=>rmSync('allure-results',{recursive:true,force:true}))\"",
    "allure:serve": "allure serve allure-results",

    "test": "pnpm allure:clean && vitest run",
    "test:allure": "pnpm test && pnpm allure:serve",
    "test:watch": "pnpm allure:clean && vitest",

    "build": "pnpm build:packages",
    "build:studiocms": "pnpm build:packages",
    "build:packages": "pnpm ci:snapshot-templates && pnpm --filter studiocms --filter create-studiocms --filter effectify --filter @studiocms/* --filter @withstudiocms/* build",

    "create-migration": "pnpm --filter @withstudiocms/sdk create-migration",

    "playground:dev": "pnpm dev",
    "playground:preview": "pnpm --filter node-playground preview",
    "playground:build": "pnpm --filter node-playground build",
    "playground:cli": "pnpm --filter node-playground studiocms",
    "playground:migrate": "pnpm --filter node-playground migrate",

    "predev": "pnpm --filter studiocms --filter effectify --filter @studiocms/* --filter @withstudiocms/* build",
    "dev": "pnpm --filter node-playground dev",

    "ci:snapshot-templates": "node ./scripts/snapshot-templates.mjs",
    "ci:update-templates": "node ./scripts/update-templates.mjs",

    "ci:lint": "biome ci --reporter=github",
    "ci:install": "pnpm install --frozen-lockfile",
    "ci:version": "pnpm changeset version && pnpm ci:update-templates && pnpm install --no-frozen-lockfile && pnpm run lint:fix",
    "ci:publish": "pnpm changeset publish",
    "ci:snapshot": "pnpx pkg-pr-new publish --pnpm './packages/*'",

    "ci:vitest": "vitest run --coverage",
    "ci:test": "allure run -- pnpm ci:vitest",
    "ci:build": "pnpm build:packages",

    "allure:view": "allure open allure-report",

    "ci:typecheck:studiocms": "pnpm --filter studiocms typecheck",
    "ci:typecheck:studiocms-packages": "pnpm --filter @studiocms/* --filter create-studiocms typecheck",
    "ci:typecheck:withstudiocms": "pnpm --filter @withstudiocms/* --filter effectify typecheck",

    "effect-check:studiocms": "pnpm --filter studiocms effect-check",
    "effect-check:studiocms-packages": "pnpm --filter @studiocms/* --filter create-studiocms effect-check",
    "effect-check:withstudiocms": "pnpm --filter @withstudiocms/* --filter effectify effect-check",

    "ci:effect-check:studiocms": "pnpm --filter studiocms ci:effect-check",
    "ci:effect-check:studiocms-packages": "pnpm --filter @studiocms/* --filter create-studiocms -r --workspace-concurrency=1 ci:effect-check",
    "ci:effect-check:withstudiocms": "pnpm --filter @withstudiocms/* --filter effectify -r --workspace-concurrency=1 ci:effect-check"
  },
  "devDependencies": {
    "@actions/core": "^3.0.1",
    "@allurereport/plugin-awesome": "^3.14.2",
    "@biomejs/biome": "^2.5.3",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@changesets/config": "^3.1.4",
    "@changesets/write": "^0.4.0",
    "@crowdin/crowdin-api-client": "^1.56.1",
    "@dotenvx/dotenvx": "^2.4.1",
    "@effect/language-service": "^0.86.6",
    "@effect/vitest": "^0.29.0",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "^3.2.4",
    "@withstudiocms/buildkit": "workspace:^",
    "allure": "^3.14.2",
    "allure-js-commons": "^3.10.2",
    "allure-vitest": "^3.10.2",
    "execa": "^9.6.1",
    "knip": "^6.26.0",
    "pkg-pr-new": "^0.0.75",
    "publint": "^0.3.21",
    "studiocms": "workspace:^",
    "tinyglobby": "catalog:",
    "typescript": "catalog:",
    "ts-patch": "^4.0.1",
    "tsdown": "catalog:",
    "vite": "catalog:astrojs-current",
    "vitest": "^3.2.4",
    "jsdom": "^29.1.1"
  }
}
