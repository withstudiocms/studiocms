---
import 'studiocms:ui/reset-css';
import 'studiocms:ui/global-css';
import '../styles/dashboard-base.css';
import type { ComponentProps } from 'astro/types';
import BaseLayout from './BaseLayout.astro';
import { LAYOUT_IDS } from '#frontend/consts.ts';

interface Props extends ComponentProps<typeof BaseLayout> {}

const headProps = Astro.props;
---

<BaseLayout {...headProps} generators={false} id={LAYOUT_IDS.dashboard}>
  <main>
    <div class="container">
      <slot />
    </div>
  </main>
  <style>
    .container {
      margin: 0 auto;
      padding: 0 1rem;
      padding-top: 2rem;
      display: flex;
      flex-direction: column;
      height: 100vh;
      width: 100%;
    }
  </style>
</BaseLayout>
