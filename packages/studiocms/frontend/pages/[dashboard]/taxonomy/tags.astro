---
import { useTranslations } from 'studiocms:i18n';
import { Input } from 'studiocms:ui/components/input';
import { setDataContext } from '@withstudiocms/effect/astro/data-middleware';
import MetaContainer from '#frontend/components/dashboard/taxonomy/MetaContainer.astro';
import TaxonomyLayout from '#frontend/layouts/TaxonomyLayout.astro';

const { defaultLang: lang } = Astro.locals.StudioCMS;

const t = useTranslations(lang, '@studiocms/dashboard:taxonomy-index');

setDataContext(Astro, {
	key: 'x-required-role',
	value: 'editor',
});
setDataContext(Astro, {
	key: 'x-redirect-url',
	value: Astro.locals.StudioCMS.routeMap.mainLinks.dashboardIndex,
});
---
<TaxonomyLayout type='tags'>
    <form 
        id="tag-form" 
        action={Astro.locals.StudioCMS.routeMap.endpointLinks.taxonomy} 
        method="post"
    >

        <input type="hidden" name="mode" value="create" />
        <input type="hidden" name="id" value="" />

        <div class="form-row">
            <Input id="name" name="name" label={t('label-name')} isRequired />
            <Input id="slug" name="slug" label={t('label-slug')} isRequired />
        </div>

        <Input
            id="description"
            name="description"
            label={t('label-description')}
        />

        <MetaContainer name="meta">
            <Fragment slot="title">
                <t-taxonomy key="label-meta">
                    {t('label-meta')}
                </t-taxonomy>
            </Fragment>
            <Fragment slot="key-label">
                <t-taxonomy key="label-meta-key">
                    {t('label-meta-key')}
                </t-taxonomy>
            </Fragment>
            <Fragment slot="value-label">
                <t-taxonomy key="label-meta-value">
                    {t('label-meta-value')}
                </t-taxonomy>
            </Fragment>
            <Fragment slot="alert-message-keys-empty">
                <t-taxonomy key="meta-alert-message-keys-empty">
                    {t('meta-alert-message-keys-empty')}
                </t-taxonomy>
            </Fragment>
            <Fragment slot="alert-message-duplicate-keys">
                <t-taxonomy key="meta-alert-message-duplicate-keys">
                    {t('meta-alert-message-duplicate-keys')}
                </t-taxonomy>
            </Fragment>
        </MetaContainer>

    </form>
</TaxonomyLayout>

<script>
    import {
        $i18n,
        baseTranslation,
        updateElmLabel,
    } from "studiocms:i18n/client";

    const currentPage = "@studiocms/dashboard:taxonomy-index";

    const i18n = $i18n(currentPage, baseTranslation[currentPage]);

    i18n.subscribe((comp) => {
        updateElmLabel('name', comp['label-name']);
        updateElmLabel('slug', comp['label-slug']);
        updateElmLabel('description', comp['label-description']);
    });
</script>

<script>
    import { getCurrentEntryData, parseFormDataToJson } from "./shared-client.js";
    import { toast } from 'studiocms:ui/components/toaster/client';
    import { dashboardClient, dashboardSharedCatchTags } from 'studiocms:client/apiClients';
    import * as Effect from 'effect/Effect';

    const $ = <E extends HTMLElement>(selector: string, context: Document | Element = document) =>
        context.querySelector(selector) as E;

    const form = $("#tag-form") as HTMLFormElement;

    const dataEl = $("#current-taxonomy-entry-data");
    const modeInput = $<HTMLInputElement>('input[name="mode"]', form);
    const idInput = $<HTMLInputElement>('input[name="id"]', form);
    const titleInput = $<HTMLInputElement>('input[name="name"]', form);
    const slugInput = $<HTMLInputElement>('input[name="slug"]', form);
    const descriptionInput = $<HTMLInputElement>('input[name="description"]', form);
    const metaContainer = $<HTMLElement>(
        `dynamic-key-value-pair[name="meta"]`,
        form
    );

    const currentData = getCurrentEntryData<"tags">(dataEl);

    function populate() {
        modeInput.value = dataEl.dataset.mode || 'create';
        if (dataEl.dataset.mode === "edit") {
            idInput.value = String(currentData.currentEntry.id || "");
            titleInput.value = currentData.currentEntry.name || "";
            slugInput.value = currentData.currentEntry.slug || "";
            descriptionInput.value = currentData.currentEntry.description || "";
            metaContainer.setAttribute(
                "entries",
                JSON.stringify(currentData.currentEntry.meta || {}),
            );

        }
    }

    function loadForm() {
        const redirectUrl = dataEl.dataset.redirect;
        
        form.addEventListener('submit', async (e) => {
            e.preventDefault();

            const formData = new FormData(form);
            const jsonData = parseFormDataToJson(formData, 'tags');

            const response = await dashboardClient.pipe(
                Effect.flatMap((client) =>
                    client.taxonomy.taxonomy({
                        payload: jsonData,
                    })
                ),
                Effect.catchTags(dashboardSharedCatchTags),
                Effect.runPromise
            );

            if ('error' in response) {
                toast({
                    title: 'Error',
                    description: response.error,
                    type: 'danger',
                });
                return;
            } else {
                toast({
                    title: 'Success',
                    description: response.message || 'Tag saved successfully.',
                    type: 'success',
                });

                if (redirectUrl) {
                    window.location.href = redirectUrl;
                }
                return;
            }
        })
    }

    document.addEventListener("DOMContentLoaded", () => {
        populate();
        loadForm();
    });
</script>

<style>
    #tag-form {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        margin-top: 1rem;
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.75rem;
    }

    @media (max-width: 600px) {
        .form-row {
            grid-template-columns: 1fr;
        }
    }
</style>