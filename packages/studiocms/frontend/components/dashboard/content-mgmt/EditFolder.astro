---
import { type UiLanguageKeys, useTranslations } from 'studiocms:i18n';
import type { FolderListItem, tsPageFolderSelect } from 'studiocms:sdk/types';
import { Input } from 'studiocms:ui/components/input';
import { Select } from 'studiocms:ui/components/select';

interface Props {
	lang: UiLanguageKeys;
	currentFolder: tsPageFolderSelect;
	folderList: FolderListItem[];
}

const { lang, currentFolder, folderList } = Astro.props;

const t = useTranslations(lang, '@studiocms/dashboard:content-folder');

const filteredParentFolderOptions = [
	{ value: 'null', label: 'None' },
	...folderList.map(({ id: value, name: label }) => ({ value, label })),
].filter((option) => option.value !== currentFolder.id);
---

<div
    id="edit-folder-container"
    data-content-management-url={Astro.locals.StudioCMS.routeMap.mainLinks
        .contentManagement}
>
    <form
        id="edit-folder-form"
        action={Astro.locals.StudioCMS.routeMap.endpointLinks.content.folder}
    >
        <input type="hidden" name="folder-id" value={currentFolder.id} />

        <Input
            label={t("input-folder-name")}
            name="folder-name"
            defaultValue={currentFolder.name}
            isRequired
        />

        <Select
            label={t("input-folder-parent")}
            name="parent-folder"
            options={filteredParentFolderOptions}
            defaultValue={currentFolder.parent || "null"}
            fullWidth
        />
    </form>
</div>

<script>
    import {
        $i18n,
        baseTranslation,
        updateElmLabel,
        updateSelectElmLabel,
    } from "studiocms:i18n/client";

    const currentPage = "@studiocms/dashboard:content-folder";

    const i18n = $i18n(currentPage, baseTranslation[currentPage]);

    i18n.subscribe((comp) => {
        updateElmLabel("folder-name", comp["input-folder-name"]);
        updateSelectElmLabel("parent-folder", comp["input-folder-parent"]);
    });
</script>

<script>
    import { toast } from "studiocms:ui/components/toaster/client";
    import { dashboardClient } from "studiocms:client/apiClients";
    import * as Effect from "effect/Effect";

    const form = document.getElementById("edit-folder-form") as HTMLFormElement;

    form.addEventListener("submit", async (e) => {
        e.preventDefault();

        const formData = new FormData(form);

        function parseParentFolder(value: string) {
            if (value === "null") {
                return null;
            }

            return value;
        }

        type JsonData = {
            id: string;
            folderName: string;
            parentFolder: string | null;
        };

        const data: JsonData = {
            id: formData.get("folder-id") as string,
            folderName: formData.get("folder-name") as string,
            parentFolder: parseParentFolder(
                formData.get("parent-folder") as string,
            ),
        };

        const response = await dashboardClient.pipe(
            Effect.flatMap((client) =>
                client.content.updateFolder({
                    payload: data,
                }),
            ),
            Effect.catchTags({
                AstroLocalsMissing: (err) =>
                    Effect.succeed({
                        error:
                            err.message ||
                            "An error occurred while updating the folder",
                    }),
                DashboardAPIError: (err) =>
                    Effect.succeed({
                        error:
                            err.message ||
                            "An error occurred while updating the folder",
                    }),
                HttpApiDecodeError: (err) =>
                    Effect.succeed({
                        error:
                            err.message ||
                            "An error occurred while updating the folder",
                    }),
                ParseError: (err) =>
                    Effect.succeed({
                        error:
                            err.message ||
                            "An error occurred while updating the folder",
                    }),
                RequestError: (err) =>
                    Effect.succeed({
                        error:
                            err.message ||
                            "An error occurred while updating the folder",
                    }),
                ResponseError: (err) =>
                    Effect.succeed({
                        error:
                            err.message ||
                            "An error occurred while updating the folder",
                    }),
            }),
            Effect.runPromise,
        );

        if ("error" in response) {
            toast({
                title: "Error",
                description: response.error,
                type: "danger",
            });
            return;
        } else {
            toast({
                title: "Success",
                description: response.message || "Folder updated successfully",
                type: "success",
            });
        }
    });
</script>

<style>
    #edit-folder-container {
        height: 100%;
        width: 100%;
        min-width: 100%;
    }

    #edit-folder-form {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        padding-top: 0.5rem;
    }
</style>
