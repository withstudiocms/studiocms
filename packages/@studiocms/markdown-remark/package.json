{
  "name": "@studiocms/markdown-remark",
  "version": "1.3.1",
  "type": "module",
  "author": "studiocms",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/withstudiocms/studiocms.git",
    "directory": "packages/@studiocms/markdown-remark"
  },
  "bugs": "https://github.com/withstudiocms/studiocms/issues",
  "homepage": "https://studiocms.dev",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/integration/components/live.d.ts",
      "default": "./dist/integration/components/live.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "default": "./dist/core/index.js"
    },
    "./core/frontmatter": {
      "types": "./dist/core/frontmatter.d.ts",
      "default": "./dist/core/frontmatter.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "default": "./dist/errors.js"
    },
    "./integration": {
      "types": "./dist/integration/index.d.ts",
      "default": "./dist/integration/index.js"
    },
    "./shared": {
      "types": "./dist/integration/shared.d.ts",
      "default": "./dist/integration/shared.js"
    },
    "./styles/*": "./dist/styles/*",
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./utils": {
      "types": "./dist/integration/utils.d.ts",
      "default": "./dist/integration/utils.js"
    }
  },
  "scripts": {
    "prepublish": "pnpm build",
    "build": "tsdown --config tsdown.config.ts --clean",
    "dev": "tsdown --config tsdown.config.ts --no-clean",
    "test": "vitest"
  },
  "publishConfig": {
    "provenance": true
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@withstudiocms/internal_helpers": "workspace:^",
    "github-slugger": "^2.0.0",
    "hastscript": "^9.0.1",
    "hast-util-from-html": "^2.0.3",
    "hast-util-is-element": "^3.0.0",
    "hast-util-to-string": "^3.0.1",
    "html-escaper": "^3.0.3",
    "import-meta-resolve": "^4.2.0",
    "js-yaml": "^5.2.1",
    "mdast-util-definitions": "^6.0.0",
    "mdast-util-find-and-replace": "^3.0.2",
    "rehype-raw": "^7.0.0",
    "rehype-stringify": "^10.0.1",
    "rehype-autolink-headings": "^7.1.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "remark-smartypants": "^3.0.2",
    "smol-toml": "^1.7.0",
    "ultrahtml": "catalog:",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "vfile": "^6.0.3"
  },
  "devDependencies": {
    "@types/estree": "^1.0.9",
    "@types/hast": "^3.0.5",
    "@types/html-escaper": "^3.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/mdast": "^4.0.4",
    "@types/unist": "^3.0.3",
    "astro": "catalog:astrojs-current",
    "mdast-util-mdx-expression": "^2.0.1"
  },
  "peerDependencies": {
    "@astrojs/internal-helpers": "catalog:astrojs-min",
    "astro": "catalog:astrojs-min",
    "vite": "catalog:astrojs-min"
  }
}