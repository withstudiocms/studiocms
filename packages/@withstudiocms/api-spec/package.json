{
	"name": "@withstudiocms/api-spec",
	"version": "0.4.0",
	"description": "API Specification for StudioCMS",
	"license": "MIT",
	"author": {
		"name": "withstudiocms",
		"url": "https://studiocms.dev"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/withstudiocms/studiocms.git",
		"directory": "packages/@withstudiocms/api-spec"
	},
	"keywords": [
		"studiocms",
		"effect",
		"effect-ts",
		"effect-ts-astro"
	],
	"homepage": "https://studiocms.dev",
	"contributors": [
		"Adammatthiesen",
		"jdtjenkins",
		"dreyfus92",
		"code.spirit"
	],
	"type": "module",
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"sideEffects": false,
	"files": [
		"dist",
		"LICENSE",
		"CHANGELOG.md",
		"README.md"
	],
	"scripts": {
		"build": "tsdown --clean",
		"dev": "tsdown --no-clean",
		"docs": "tsx ./scripts/test-srv.ts",
		"effect-check": "pnpm effect-language-service diagnostics --project tsconfig.tspc.json",
		"ci:effect-check": "pnpm effect-check --format github-actions",
		"typecheck": "tspc -p tsconfig.tspc.json"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./astro-context": {
			"types": "./dist/astro-context.d.ts",
			"default": "./dist/astro-context.js"
		},
		"./auth": {
			"types": "./dist/auth/index.d.ts",
			"default": "./dist/auth/index.js"
		},
		"./consts": {
			"types": "./dist/consts.d.ts",
			"default": "./dist/consts.js"
		},
		"./dashboard": {
			"types": "./dist/dashboard/index.d.ts",
			"default": "./dist/dashboard/index.js"
		},
		"./integrations": {
			"types": "./dist/integrations/index.d.ts",
			"default": "./dist/integrations/index.js"
		},
		"./rest-api": {
			"types": "./dist/rest-api/index.d.ts",
			"default": "./dist/rest-api/index.js"
		},
		"./sdk": {
			"types": "./dist/sdk/index.d.ts",
			"default": "./dist/sdk/index.js"
		}
	},
	"dependencies": {
		"effectify": "workspace:^"
	},
	"peerDependencies": {
		"@effect/platform": "catalog:effect",
		"@effect/platform-node": "catalog:effect",
		"@withstudiocms/sdk": "workspace:^",
		"astro": "catalog:studiocms-peerlock",
		"effect": "catalog:effect"
	}
}